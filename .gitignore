# ── Credentials & secrets ─────────────────────────────────────────────────────
.env
*.json
# Frontend config JSON must be tracked. The generated dataset
# (web/public/data/results.json) stays ignored — built fresh in CI and shipped
# in the Pages artifact, never committed (fixes the daily gitlink churn).
!web/package.json
!web/tsconfig.json
!web/tsconfig.node.json
# If you ever download your service account key into the project folder,
# this prevents it from being committed. Keep it outside the repo if possible.

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env/          # folder named .env (different from the .env secrets file)

# ── Frontend (Vite SPA under web/) ────────────────────────────────────────────
node_modules/
web/dist/

# ── Output / data files ───────────────────────────────────────────────────────
*.csv
*.xlsx

# ── OS clutter ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace